# ──────────────────────────────────────────────────────────────────────────────
# Configurazione npm/yarn per gsposte-server
# ──────────────────────────────────────────────────────────────────────────────
#
# Nota sicurezza: ignore-scripts=false è VOLUTO.
#
# Dipendenze legittime che richiedono postinstall:
#   - bcrypt (se mai usato in deps transitiva): compila binding nativo
#   - puppeteer: scaricherebbe Chromium. Per disabilitare quel download,
#     impostiamo PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true nel Dockerfile, così
#     lo script "postinstall" di puppeteer parte ma non scarica nulla.
#
# La supply-chain è protetta da:
#   1. lockfile esatto (yarn.lock) committato
#   2. --frozen-lockfile in Dockerfile
#   3. audit-level=high qui sotto
#   4. container runtime con cap_drop=ALL e user non-root
#   5. nessuna installazione npm a runtime (immagine immutabile)

audit-level=high
fund=false
loglevel=warn
save-exact=true
package-lock=true
