node_modules/
dist/
*.tsbuildinfo

# Env files — NIENTE segreti in git.
# I file `.env.production`, `.env.development`, `.env.test` storicamente
# committati in questo repo contengono credenziali ormai morte (Postel,
# FIC, SendGrid, SMS, ecc) della società precedente, vanno rimossi
# dalla history (BFG / git-filter-repo).
.env
.env.*
!.env.example

# Assets
test/assets/pdf/GSTESTPDF21/postel.pdf
test/assets/pdf/GSTESTPDF21/invoice.pdf
test/assets/*.html
test/assets/.~lock*
test/assets/pdf/invoices/

# Log files
*.log

# PDF and XLSX files
!public/pdf/.gitkeep
!public/xlsx/.gitkeep
!public/invoices/.gitkeep
!public/attachments/.gitkeep
public/pdf/
public/xlsx/
public/invoices/
public/attachments/
public/logs/
public/images/

# Lock files
.~lock.*
