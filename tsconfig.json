{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "dist",
        "lib": [ "es2016" ],
        "noImplicitAny": true,
        "removeComments": true,
        "sourceMap": true,
        "inlineSources": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": [ "reflect-metadata", "mocha" ],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
