# ════════════════════════════════════════════════════════════════════
#  gsposte-server — file di esempio variabili d'ambiente
#
#  In produzione le variabili vengono passate dal compose dell'orchestratore
#  (posteway-orch/compose.yaml). Questo file è solo per sviluppo standalone.
#
#  Generate i segreti:  openssl rand -hex 32
# ════════════════════════════════════════════════════════════════════

NODE_ENV=development

# Server
SERVER_HOST=http://localhost
SERVER_PORT=5000
API_PATH=/api
IMAGES_PATH=/images

# Authentication
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# MongoDB (dedicato a gsposte, NON quello di posteway)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_NAME=gsposte_dev

# Utente system (creato al primo boot dal codice)
SYSTEM_PASS=CHANGE_ME_strong_password

# ─── Postel — DISABILITATO ──────────────────────────────────────────
# Lasciato vuoto al day-1. Il PostelService al primo tentativo fallirà
# in auth: questo è VOLUTO perché tutti i flussi che richiedono Postel
# vanno disattivati a livello UI/business prima del go-live.
POSTEL_ZCODE=
POSTEL_USERNAME=
POSTEL_PASSWORD=

# ─── PosteWay (posteway-api interno) ────────────────────────────────
# In docker compose risolvi con http://posteway-api:5000 (rete interna).
# In dev locale fuori da docker: http://localhost:8000/api
PW_ENDPOINT=http://localhost:8000
PW_TOKEN=CHANGE_ME_openssl_rand_hex_32
PW_CONFIRM_WAIT_MS=90000
PW_TRACK_WAIT_MS=30000

# ─── Sms ────────────────────────────────────────────────────────────
SMS_ENDPOINT=
SMS_USERNAME=
SMS_PASSWORD=

# ─── Misc ───────────────────────────────────────────────────────────
CURRENT_ENVELOPE_ID=0
LETTER_BBOXES=true

# ─── CRON ───────────────────────────────────────────────────────────
CRON_UPLOAD=0 0 8,13,22 * * *
CRON_QUERY=0 0 6,10,16 * * *

# ─── Fatture in Cloud ───────────────────────────────────────────────
FIC_API_UID=
FIC_API_KEY=
FIC_IBAN=
DEFAULT_REDIRECT_URI=http://localhost:4200/fic/redirect
FIC_CLIENT_ID=
FIC_CLIENT_SECRET=

# ─── Revenue Share ──────────────────────────────────────────────────
# IBAN di Solutions S.r.l. per il payout del residuo (80%).
# Se assente, fallback su FIC_IBAN (per retro-compatibilità).
SOLUTIONS_IBAN=

# ─── Resend (email transazionali) ───────────────────────────────────
# API key dalla dashboard Resend (https://resend.com/api-keys)
RESEND_API_KEY=
# Indirizzo mittente. Deve essere su un dominio verificato in Resend.
# Formato accettato: "Display Name <email@domain.tld>" oppure solo "email@domain.tld"
RESEND_FROM_ADDRESS=PortalePostale <noreply@comunicazioni.portalepostale.it>

# ─── Sentry ─────────────────────────────────────────────────────────
SENTRY_DSN=
